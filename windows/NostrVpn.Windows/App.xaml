<Application x:Class="NostrVpn.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NostrVpn.Windows"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
    <local:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVisibility" />
    <local:ObjectToVisibilityConverter x:Key="ObjectToVisibility" />
    <local:NullToVisibilityConverter x:Key="NullToVisibility" />
    <local:PageVisibilityConverter x:Key="PageVisibility" />

    <SolidColorBrush x:Key="WindowBg" Color="#F6F7F8" />
    <SolidColorBrush x:Key="PanelBg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SidebarBg" Color="#ECEFF2" />
    <SolidColorBrush x:Key="TextPrimary" Color="#17202A" />
    <SolidColorBrush x:Key="TextSecondary" Color="#68717C" />
    <SolidColorBrush x:Key="Accent" Color="#7C3AED" />
    <SolidColorBrush x:Key="AccentSoft" Color="#F0E8FF" />
    <SolidColorBrush x:Key="Ok" Color="#12A150" />
    <SolidColorBrush x:Key="Warn" Color="#A16207" />
    <SolidColorBrush x:Key="Danger" Color="#DC2626" />
    <SolidColorBrush x:Key="Line" Color="#DDE3EA" />

    <Style TargetType="{x:Type Window}">
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style x:Key="Card" TargetType="{x:Type Border}">
      <Setter Property="Background" Value="{StaticResource PanelBg}" />
      <Setter Property="BorderBrush" Value="{StaticResource Line}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="0,0,0,14" />
    </Style>

    <Style TargetType="{x:Type Button}">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#CCD5DF" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{StaticResource Accent}" />
      <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="NavButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="BorderBrush" Value="#C9D2DC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#FFFFFF" />
    </Style>

    <Style TargetType="{x:Type CheckBox}">
      <Setter Property="Margin" Value="0,4,18,4" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Application.Resources>
</Application>
