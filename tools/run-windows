#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/windows-build.ps1" -Run "$@"
fi

exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/windows-build.ps1" -Run "$@"
