#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT/linux"

if ! command -v docker >/dev/null 2>&1; then
    echo "Docker is required for the Linux desktop dev environment." >&2
    exit 1
fi

docker compose up -d --build

if [ "$#" -eq 0 ]; then
    set -- cargo run
fi

exec_args=()
if [ ! -t 0 ]; then
    exec_args=(-T)
fi

docker compose exec "${exec_args[@]}" nostr-vpn-linux /usr/local/bin/dev-entrypoint "$@"
