#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CORE_DIR="$ROOT/crates/nostr-vpn-app-core"
MACOS_DIR="$ROOT/macos"
BINDINGS_DIR="$MACOS_DIR/Bindings"
FRAMEWORKS_DIR="$MACOS_DIR/Frameworks"
BUILD_DIR="$MACOS_DIR/.build"
PROFILE="${NVPN_MACOS_RUST_PROFILE:-debug}"
TARGETS="${NVPN_MACOS_RUST_TARGETS:-$(rustc -vV | awk '/host:/ {print $2}')}"
XCODE_CONFIGURATION="${NVPN_MACOS_XCODE_CONFIGURATION:-Debug}"
PROJECT="$MACOS_DIR/NostrVpnMac.xcodeproj"
SCHEME="NostrVpnMac"

usage() {
  cat <<'EOF'
usage: ./scripts/macos-build <macos-gen-swift|macos-rust|macos-xcframework|macos-xcodeproj|macos-build>
EOF
}

target_root() {
  local dir="${CARGO_TARGET_DIR:-$ROOT/target}"
  if [[ "$dir" = /* ]]; then
    printf '%s\n' "$dir"
  else
    printf '%s/%s\n' "$ROOT" "$dir"
  fi
}

host_dynamic_lib() {
  printf '%s/%s/libnostr_vpn_app_core.dylib\n' "$(target_root)" "$PROFILE"
}

target_static_lib() {
  local target="$1"
  printf '%s/%s/%s/libnostr_vpn_app_core.a\n' "$(target_root)" "$target" "$PROFILE"
}

run_macos_gen_swift() {
  if [[ "$PROFILE" == "release" ]]; then
    cargo build -p nostr-vpn-app-core --release
  else
    cargo build -p nostr-vpn-app-core
  fi
  rm -rf "$BINDINGS_DIR"
  mkdir -p "$BINDINGS_DIR"
  cargo run -q --manifest-path "$CORE_DIR/uniffi-bindgen/Cargo.toml" -- generate \
    --library "$(host_dynamic_lib)" \
    --language swift \
    --out-dir "$BINDINGS_DIR" \
    --config "$CORE_DIR/uniffi.toml"

  while IFS= read -r -d '' generated_file; do
    perl -0777 -pi -e 's/[ \t]+$//mg; s/\n*\z/\n/' "$generated_file"
  done < <(find "$BINDINGS_DIR" -type f \( -name '*.swift' -o -name '*.h' -o -name '*.modulemap' \) -print0)
}

run_macos_rust() {
  local target
  local dev_dir
  local toolchain_bin
  local cc_bin
  local cxx_bin
  local ar_bin
  local ranlib_bin
  local sdkroot
  local min_version="${NVPN_MACOS_MIN_VERSION:-14.0}"
  local arch_target

  dev_dir="$(xcode-select -p)"
  toolchain_bin="$dev_dir/Toolchains/XcodeDefault.xctoolchain/usr/bin"
  cc_bin="$toolchain_bin/clang"
  cxx_bin="$toolchain_bin/clang++"
  ar_bin="$toolchain_bin/ar"
  ranlib_bin="$toolchain_bin/ranlib"
  sdkroot="$(xcrun --sdk macosx --show-sdk-path)"

  for target in $TARGETS; do
    case "$target" in
      aarch64-apple-darwin) arch_target="arm64-apple-macos${min_version}" ;;
      x86_64-apple-darwin) arch_target="x86_64-apple-macos${min_version}" ;;
      *)
        echo "Unsupported macOS target: $target" >&2
        exit 2
        ;;
    esac

    if [[ "$PROFILE" == "release" ]]; then
      env \
        SDKROOT="$sdkroot" \
        MACOSX_DEPLOYMENT_TARGET="$min_version" \
        CC="$cc_bin" \
        CXX="$cxx_bin" \
        AR="$ar_bin" \
        RANLIB="$ranlib_bin" \
        CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
        CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
        RUSTFLAGS="-C linker=$cc_bin -C link-arg=-target -C link-arg=$arch_target -C link-arg=-mmacosx-version-min=${min_version}" \
        cargo build -p nostr-vpn-app-core --release --target "$target"

      env \
        SDKROOT="$sdkroot" \
        MACOSX_DEPLOYMENT_TARGET="$min_version" \
        CC="$cc_bin" \
        CXX="$cxx_bin" \
        AR="$ar_bin" \
        RANLIB="$ranlib_bin" \
        CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
        CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
        RUSTFLAGS="-C linker=$cc_bin -C link-arg=-target -C link-arg=$arch_target -C link-arg=-mmacosx-version-min=${min_version}" \
        cargo build -p nostr-vpn-cli --release --bin nvpn --target "$target"
    else
      env \
        SDKROOT="$sdkroot" \
        MACOSX_DEPLOYMENT_TARGET="$min_version" \
        CC="$cc_bin" \
        CXX="$cxx_bin" \
        AR="$ar_bin" \
        RANLIB="$ranlib_bin" \
        CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
        CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
        RUSTFLAGS="-C linker=$cc_bin -C link-arg=-target -C link-arg=$arch_target -C link-arg=-mmacosx-version-min=${min_version}" \
        cargo build -p nostr-vpn-app-core --target "$target"

      env \
        SDKROOT="$sdkroot" \
        MACOSX_DEPLOYMENT_TARGET="$min_version" \
        CC="$cc_bin" \
        CXX="$cxx_bin" \
        AR="$ar_bin" \
        RANLIB="$ranlib_bin" \
        CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
        CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
        RUSTFLAGS="-C linker=$cc_bin -C link-arg=-target -C link-arg=$arch_target -C link-arg=-mmacosx-version-min=${min_version}" \
        cargo build -p nostr-vpn-cli --bin nvpn --target "$target"
    fi
  done
}

run_macos_xcframework() {
  local headers_dir="$BUILD_DIR/headers"
  local universal_lib="$BUILD_DIR/libnostr_vpn_app_core_macos.a"
  local framework="$FRAMEWORKS_DIR/NostrVpnAppCore.xcframework"
  local header_path
  local modulemap_path
  local libs=()
  local target

  run_macos_gen_swift
  run_macos_rust

  header_path="$(find "$BINDINGS_DIR" -maxdepth 1 -name '*.h' | head -n 1)"
  modulemap_path="$(find "$BINDINGS_DIR" -maxdepth 1 -name '*.modulemap' | head -n 1)"
  if [[ -z "${header_path:-}" || -z "${modulemap_path:-}" ]]; then
    echo "Missing generated Swift headers/modulemap in $BINDINGS_DIR" >&2
    exit 1
  fi

  rm -rf "$headers_dir" "$universal_lib" "$framework"
  mkdir -p "$headers_dir" "$FRAMEWORKS_DIR" "$BUILD_DIR" "$MACOS_DIR/Resources/binaries"
  cp "$header_path" "$headers_dir/"
  cp "$modulemap_path" "$headers_dir/module.modulemap"

  for target in $TARGETS; do
    libs+=("$(target_static_lib "$target")")
    cp "$(target_root)/$target/$PROFILE/nvpn" "$MACOS_DIR/Resources/binaries/nvpn"
  done

  if [[ "${#libs[@]}" -eq 1 ]]; then
    cp "${libs[0]}" "$universal_lib"
  else
    lipo -create "${libs[@]}" -output "$universal_lib"
  fi

  xcodebuild -create-xcframework \
    -library "$universal_lib" \
    -headers "$headers_dir" \
    -output "$framework"
}

run_macos_xcodeproj() {
  if ! command -v xcodegen >/dev/null 2>&1; then
    echo "xcodegen is required for macOS project generation" >&2
    exit 1
  fi
  (cd "$MACOS_DIR" && xcodegen generate --spec project.yml)
}

run_macos_build() {
  local host_arch
  host_arch="$(uname -m)"
  run_macos_xcframework
  run_macos_xcodeproj
  xcodebuild \
    -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration "$XCODE_CONFIGURATION" \
    -derivedDataPath "$BUILD_DIR/DerivedData" \
    -destination "platform=macOS,arch=$host_arch" \
    CODE_SIGNING_ALLOWED=NO \
    build
}

case "${1:-}" in
  macos-gen-swift) run_macos_gen_swift ;;
  macos-rust) run_macos_rust ;;
  macos-xcframework) run_macos_xcframework ;;
  macos-xcodeproj) run_macos_xcodeproj ;;
  macos-build) run_macos_build ;;
  -h|--help|"") usage ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
